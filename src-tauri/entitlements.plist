<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Microphone access: required for audio capture -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- Outbound network: required for Supabase auth/subscription checks -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Allow JIT (required by WKWebView / Tauri renderer) -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Allow unsigned executable memory (required by some JS engines) -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>
</dict>
</plist>
